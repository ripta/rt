# Message extraction from logfmt log lines
exec cg --log-parse logfmt -- emit-logfmt-log
stdout '^O: server started$'
stdout '^O: listening on port$'
! stdout 'message='

# Field extraction appends key=value pairs
exec cg --log-parse logfmt --log-fields port -- emit-logfmt-log
stdout '^O: server started port=8080$'
